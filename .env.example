# Artemis Environment Configuration Example
# Copy this file to .env and fill in your actual values

# Ethereum WebSocket RPC endpoint (Required)
# Get this from Infura, Alchemy, or your own node
WSS=wss://eth-mainnet.alchemyapi.io/v2/YOUR_ALCHEMY_KEY
# Alternative: WSS=wss://mainnet.infura.io/ws/v3/YOUR_INFURA_KEY

# OpenSea API key (Required)
# Get this from https://docs.opensea.io/reference/api-keys
OPENSEA_API_KEY=your_opensea_api_key_here

# Private key for signing transactions (Required)
# WARNING: Keep this secure! Never commit the actual private key to version control
PRIVATE_KEY=0x1234567890abcdef1234567890abcdef1234567890abcdef1234567890abcdef

# Address of the deployed arbitrage contract (Required)
# Deploy the SudoOpenseaArb contract first and put the address here
ARB_CONTRACT_ADDRESS=0x1234567890123456789012345678901234567890

# Percentage of profit to pay in gas fees (Required)
# Value between 0-100, typically 10-50
BID_PERCENTAGE=20

# Optional: Ethereum mainnet HTTP endpoint for contract operations
ETH_MAINNET_HTTP=https://eth-mainnet.alchemyapi.io/v2/YOUR_ALCHEMY_KEY

# Optional: Monitoring and logging
RUST_LOG=info